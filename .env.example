# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=coescd
# Set to "true" to auto-run pending migrations on startup
DB_MIGRATIONS_RUN=false

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
# REQUIRED — must be at least 32 characters, keep secret!
JWT_SECRET=change_me_to_a_random_string_min_32_chars
JWT_TOKEN_AUDIENCE=coescd-client
JWT_TOKEN_ISSUER=coescd-api
# Access token TTL in seconds (default 1 hour)
JWT_TOKEN_ACCESS_TOKEN_TTL=3600
# Refresh token TTL in seconds (default 24 hours)
JWT_REFRESH_TOKEN_TTL=86400

# ─── Cookies ─────────────────────────────────────────────────────────────────
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=your-domain.com

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── File Storage ─────────────────────────────────────────────────────────────
# Use "minio" for local dev with the docker-compose MinIO container
STORAGE_BACKEND=minio
MINIO_ENDPOINT=http://localhost:9000
# MinIO root credentials (matches docker-compose.yml)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET=coescd-files

# For production S3 — set STORAGE_BACKEND=s3 and fill these in:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-central-1
# S3_BUCKET=your-production-bucket

# ─── Redis ────────────────────────────────────────────────────────────────────
# Set REDIS_DISABLED=true to fall back to in-memory (single-instance only)
REDIS_DISABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
# Matches the password in docker-compose.yml
REDIS_PASSWORD=redis_secret

# ─── WebRTC / TURN ───────────────────────────────────────────────────────────
# Leave empty to use public STUN servers only (sufficient for dev)
TURN_HOST=
TURN_SECRET=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8008
NODE_ENV=development
